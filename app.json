{
  "expo": {
    "name": "KidPoints",
    "slug": "KidPoints",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "scheme": "kidpoints",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.KidPoints"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow KidPoints to capture item photos for the shop.",
          "photosPermission": "Allow KidPoints to choose item photos for the shop."
        }
      ]
    ]
  }
}
