<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:paddingLeft="16dp"
  android:paddingTop="14dp"
  android:paddingRight="16dp"
  android:paddingBottom="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/notification_expired_icon"
      android:layout_width="44dp"
      android:layout_height="44dp"
      android:contentDescription="@null"
      android:padding="8dp"
      android:src="@android:drawable/ic_lock_idle_alarm"
      android:tint="#7C6CFF" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginLeft="12dp"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/notification_expired_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/notification_expired_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#FFE5E7EB"
        android:textSize="14sp" />

      <TextView
        android:id="@+id/notification_expired_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#FFCBD5E1"
        android:textSize="13sp" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/notification_expired_check_in"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:paddingTop="10dp"
      android:paddingBottom="10dp"
      android:text="Check-in"
      android:textColor="#FFFFFFFF"
      android:textSize="16sp"
      android:textStyle="bold" />

    <View
      android:layout_width="1dp"
      android:layout_height="20dp"
      android:background="#3F475569" />

    <TextView
      android:id="@+id/notification_expired_stop"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:paddingTop="10dp"
      android:paddingBottom="10dp"
      android:text="Stop"
      android:textColor="#FFFFFFFF"
      android:textSize="16sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
