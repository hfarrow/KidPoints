{
  "name": "kidpoints",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "yarn exec biome check --write . && yarn exec eslint . --fix --cache --cache-location .cache/eslintcache && yarn exec tsc --noEmit --incremental --tsBuildInfoFile .cache/typecheck.tsbuildinfo",
    "test": "jest --runInBand --watchAll=false",
    "verify": "yarn check && yarn test",
    "clean:tooling": "node -e \"require('fs').rmSync('.cache', { recursive: true, force: true })\""
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^9.7.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
