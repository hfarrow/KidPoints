{
  "name": "kidpoints",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "clean:cache": "node -e \"require('fs').rmSync('.cache', { recursive: true, force: true })\"",
    "check": "yarn exec biome check . && yarn exec eslint . --cache --cache-location .cache/eslintcache && yarn exec tsc --noEmit --incremental --tsBuildInfoFile .cache/typecheck.tsbuildinfo",
    "check-fix": "yarn exec biome check --write . && yarn exec eslint . --fix --cache --cache-location .cache/eslintcache && yarn exec tsc --noEmit --incremental --tsBuildInfoFile .cache/typecheck.tsbuildinfo",
    "test": "jest --runInBand --watchAll=false",
    "verify": "yarn check-fix && yarn test",
    "launch:as": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-android-studio.ps1",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "^55.0.13",
    "expo-image-picker": "^55.0.18",
    "expo-intent-launcher": "^55.0.12",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-logs": "^5.6.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@biomejs/biome": "^2.4.10",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^9.7.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
